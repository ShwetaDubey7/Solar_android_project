<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/white"
    tools:context="com.solaro.app.activity.RequestMaintenanceActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="Maintenance Request"
        android:textColor="@color/primaryColor"
        android:textSize="28sp"
        android:textStyle="bold"
        tools:ignore="HardcodedText,TextContrastCheck" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Describe the issue..."
        app:boxBackgroundMode="none"
        tools:ignore="HardcodedText">

           <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etMaintDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/edittext_rounded_bg"
            android:gravity="top"
            android:minLines="3"
            android:padding="16dp"
            tools:ignore="SpeakableTextPresentCheck,VisualLintTextFieldSize" />
    </com.google.android.material.textfield.TextInputLayout>

    <ImageView
        android:id="@+id/ivPhotoPreview"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginTop="16dp"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_camera"
        android:background="#E0E0E0"
        android:contentDescription="Photo Preview"
        tools:ignore="HardcodedText" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnTakePhoto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="Take Photo"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_marginTop="8dp"
        tools:ignore="HardcodedText" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSubmitTicket"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Submit Ticket"
        android:background="@drawable/button_bg"
        app:backgroundTint="@color/primaryColor"
        android:textColor="@color/white"
        android:layout_marginTop="24dp"
        tools:ignore="HardcodedText" />

</LinearLayout>
